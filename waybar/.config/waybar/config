{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin": "8 12 0 12",
  "spacing": 8,
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "custom/notifications",
    "clock"
  ],
  "modules-right": [
    "tray",
    "mpris",
    "network",
    "cpu",
    "memory",
    "pulseaudio",
    "battery",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": " {}",
    "separate-outputs": true,
    "max-length": 60
  },
  "tray": {
    "icon-size": 22,
    "spacing": 18
  },
  "clock": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "format-alt": " {:%Y-%m-%d %H:%M}",
    "tooltip-format": "<small>{calendar}</small>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 2,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },
  "cpu": {
    "interval": 2,
    "format": "{usage}% ",
    "tooltip": true,
    "on-click-right": "foot -e btop"
  },
  "memory": {
    "interval": 5,
    "format": "{percentage}% ",
    "on-click-right": "foot -e btop"
  },
  "network": {
    "interval": 3,
    "format-wifi": "{icon}",
    "format-alt": "{essid} {icon}",
    "format-ethernet": "{bandwidthUpBits}/{bandwidthDownBits} 󰈀",
    "format-disconnected": "⚠",
    "tooltip-format": "{ifname} {ipaddr}/{cidr}",
    "format-icons": [
      "󰤯",
      "󰤟",
      "󰤥",
      "󰤨"
    ],
    "on-click-right": "nm-connection-editor"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% 󰂄",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ],
    "on-click-right": "~/.config/waybar/scripts/power-menu.sh"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}",
    "format-alt": "{volume}% {icon}",
    "format-muted": "",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    },
    "on-click-right": "pavucontrol"
  },
  "mpris": {
    "format": "{player_icon} {title}",
    "format-paused": "{status_icon} {title}",
    "player-icons": {
      "default": "▶",
      "mpv": "🎵"
    },
    "status-icons": {
      "paused": "⏸"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next"
  },
  "custom/power": {
    "tooltip": false,
    "format": "\uf011",
    "on-click": "~/.config/waybar/scripts/power-menu.sh"
  },
  "custom/notifications": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "󰂝",
      "none": "󰂚",
      "dnd-notification": "󰪏",
      "dnd-none": "󰂛",
      "inhibited-notification": "󰂚",
      "inhibited-none": "󰂛",
      "dnd-inhibited-notification": "󰪏",
      "dnd-inhibited-none": "󰪐"
    },
    "return-type": "json",
    "exec-if": "which makoctl",
    "exec": "~/.config/waybar/scripts/notifications.sh",
    "on-click": "makoctl restore",
    "on-click-right": "makoctl dismiss --all",
    "escape": true
  }
}
