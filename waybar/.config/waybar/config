{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin": "8 12 0 12",
  "spacing": 8,
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "custom/notifications",
    "clock"
  ],
  "modules-right": [
    "mpris",
    "tray",
    "network",
    "cpu",
    "memory",
    "pulseaudio",
    "battery",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "´äá",
      "2": "´ë¿",
      "3": "´åÂ",
      "4": "´âá",
      "5": "´üÁ",
      "default": "´äæ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": "´üö {}",
    "separate-outputs": true,
    "max-length": 60
  },
  "tray": {
    "icon-size": 22,
    "spacing": 18
  },
