{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "reload_style_on_change": true,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "network",
        "cpu",
        "memory",
        "pulseaudio",
        "battery"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΕι ",
            "2": "ΎΚρ ",
            "3": "ΎΕκ ",
            "4": "ΎΗ╝ ",
            "5": "ΎΒ╡ ",
            "default": "ΎΕΣ "
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "hyprland/window": {
        "format": "ΎΒΦ  {}",
        "separate-outputs": true,
        "max-length": 80
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "ΎΑΩ {:%H:%M:%S}",
        "format-alt": "ΎΒ│ {:%Y-%m-%d %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "cpu": {
        "interval": 2,
        "format": "ΎΜδ {usage:>2}%",
        "tooltip": true
    },
    "memory": {
        "interval": 5,
        "format": "Ό┐Ζ {percentage}%"
    },
    "network": {
        "interval": 3,
        "format-wifi": "{icon} {essid}",
        "format-ethernet": "≤░ΙΑ {bandwidthUpBits}/{bandwidthDownBits}",
        "format-disconnected": "έγι",
        "tooltip-format": "{ifname} {ipaddr}/{cidr}",
        "format-icons": [
            "≤░νψ",
            "≤░νθ",
            "≤░νξ",
            "≤░νρ"
        ]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ]
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-muted": "Ύγσ",
        "format-icons": {
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "on-click-right": "pavucontrol"
    }
}
