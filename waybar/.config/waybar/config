{
  "layer": "top",
  "position": "top",
  "height": 36,
  "margin": "8 12 0 12",
  "spacing": 8,
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "custom/notifications",
    "clock"
  ],
  "modules-right": [
    "tray",
    "network",
    "cpu",
    "memory",
    "pulseaudio",
    "battery",
    "custom/power"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚρ",
      "3": "ΎΗ╢",
      "4": "ΎΔι",
      "5": "ΎΒ╡",
      "default": "ΎΕΣ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": "ΎΒΦ {}",
    "separate-outputs": true,
    "max-length": 60
  },
  "tray": {
    "icon-size": 22,
    "spacing": 18
  },
  "clock": {
    "interval": 1,
    "format": "{:%H:%M:%S}",
    "format-alt": "ΎΒ│ {:%Y-%m-%d %H:%M}",
    "tooltip-format": "<small>{calendar}</small>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 2,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    }
  },
  "cpu": {
    "interval": 2,
    "format": "{usage}% ΎΜδ",
    "tooltip": true,
    "on-click-right": "foot -e btop"
  },
  "memory": {
    "interval": 5,
    "format": "{percentage}% Ό┐Ζ",
    "on-click-right": "foot -e btop"
  },
  "network": {
    "interval": 3,
    "format-wifi": "{icon}",
    "format-alt": "{essid} {icon}",
    "format-ethernet": "{bandwidthUpBits}/{bandwidthDownBits} ≤░ΙΑ",
    "format-disconnected": "έγι",
    "tooltip-format": "{ifname} {ipaddr}/{cidr}",
    "format-icons": [
      "≤░νψ",
      "≤░νθ",
      "≤░νξ",
      "≤░νρ"
    ],
    "on-click-right": "nm-connection-editor"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ≤░ΓΕ",
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ],
    "on-click-right": "~/.config/waybar/scripts/power-menu.sh"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}",
    "format-alt": "{volume}% {icon}",
    "format-muted": "Ύγσ",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑπ",
        "ΎΑρ",
        "ΎΑρ",
        "ΎΑρ"
      ]
    },
    "on-click-right": "pavucontrol"
  },
  "mpris": {
    "format": "{player_icon} {title}",
    "format-paused": "{status_icon} {title}",
    "player-icons": {
      "default": "έΨ╢",
      "mpv": "ΏθΟ╡"
    },
    "status-icons": {
      "paused": "έΠ╕"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next"
  },
  "custom/power": {
    "tooltip": false,
    "format": "\uf011",
    "on-click": "systemctl suspend -i",
    "on-click-right": "~/.config/waybar/scripts/power-menu.sh"
  },
  "custom/notifications": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤░Γζ",
      "none": "≤░Γγ",
      "dnd-notification": "≤░ςΠ",
      "dnd-none": "≤░Γδ",
      "inhibited-notification": "≤░Γγ",
      "inhibited-none": "≤░Γδ",
      "dnd-inhibited-notification": "≤░ςΠ",
      "dnd-inhibited-none": "≤░ςΡ"
    },
    "return-type": "json",
    "exec-if": "which makoctl",
    "exec": "~/.config/waybar/scripts/notifications.sh",
    "on-click": "makoctl restore",
    "on-click-right": "makoctl dismiss --all",
    "escape": true
  }
}
